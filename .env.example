# PQA configuration. Copy to .env and adjust. Never commit .env.
#
# NO API KEY REQUIRED. PQA installs into your Claude Code (project or user scope) and its
# agents run through Claude Code's own subagents — they use your existing Claude Code
# subscription/auth. You do NOT set ANTHROPIC_API_KEY for normal use.
#
PQA_BRANCHES=3            # superposition branches per run (>=1 must target the unknown)
PQA_VERIFY_TESTS=0        # 1 = run tests in the verify-loop after every edit (slow on big repos)
PQA_MODEL=opus            # every agent runs on Opus (latest)
PQA_RUN_BUDGET_USD=15     # soft per-run usage guardrail; the cost-governor warns/aborts near it
